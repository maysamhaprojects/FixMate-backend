# ============================================================
#  FixMate — application.properties (TEMPLATE)
#  Copy this file to "application.properties" and fill in your
#  own values. The real application.properties is git-ignored
#  so secrets are never committed.
# ============================================================

# --- Database ---
spring.datasource.url=jdbc:mysql://localhost:3306/fixmate_db?useSSL=false&serverTimezone=Asia/Jerusalem&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=CHANGE_ME_DB_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# --- JWT (use a long random string, at least 32 chars) ---
app.jwt.secret=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARS
app.jwt.expiration-ms=86400000

server.port=8080

# --- OpenAI (ChatGPT) — leave empty to fall back to keyword matching ---
openai.api.key=CHANGE_ME_OPENAI_API_KEY
openai.api.model=gpt-4o-mini

# ============================================================
#  Mail (Gmail SMTP) — requires a Gmail App Password (16 chars)
#  https://myaccount.google.com/apppasswords
# ============================================================
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=your-email@gmail.com
spring.mail.password=CHANGE_ME_GMAIL_APP_PASSWORD
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=5000
app.mail.from=your-email@gmail.com
# set to true to actually send emails
app.mail.enabled=false
